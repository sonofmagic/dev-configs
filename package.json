{
  "name": "icebreaker-dev-configs",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "Icebreaker's dev-configs monorepo for shared linting presets",
  "author": "ice breaker <1324318532@qq.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonofmagic/dev-configs.git"
  },
  "bugs": {
    "url": "https://github.com/sonofmagic/dev-configs/issues"
  },
  "keywords": [
    "dev-configs",
    "eslint",
    "stylelint",
    "commitlint",
    "icebreakers"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "turbo run build",
    "check:no-tracked-build-artifacts": "node ./scripts/check-no-tracked-build-artifacts.mjs",
    "dev": "turbo run dev --parallel",
    "test": "node -e \"require('node:fs').mkdirSync('coverage/.tmp', { recursive: true })\" && pnpm check:no-tracked-build-artifacts && vitest run && pnpm test:types",
    "test:dev": "node -e \"require('node:fs').mkdirSync('coverage/.tmp', { recursive: true })\" && pnpm check:no-tracked-build-artifacts && vitest",
    "test:types": "turbo run test:types",
    "test:release-scripts": "vitest run -c scripts/release/vitest.config.mjs",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "publish-packages": "turbo run build lint test test:types && changeset version && changeset publish",
    "release:publish": "node ./scripts/release/publish-for-channel.mjs",
    "release:version": "node ./scripts/release/version-for-channel.mjs",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "postinstall": "pnpm run build",
    "commit": "commit",
    "sync": "turbo run sync",
    "inspector": "npx @eslint/config-inspector",
    "build:inspector": "pnpm build && npx @eslint/config-inspector build",
    "script:init": "monorepo init",
    "script:sync": "monorepo sync",
    "script:clean": "monorepo clean",
    "script:mirror": "monorepo mirror",
    "-------": "-----------",
    "release": "changeset",
    "pr": "changeset pre enter alpha",
    "pr:beta": "changeset pre enter beta",
    "pr:rc": "changeset pre enter rc",
    "pr:exit": "changeset pre exit",
    "cv": "changeset version ",
    "--------": "----------------",
    "commitlint": "commitlint --edit"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.1.0",
    "@eslint/config-inspector": "^3.0.4",
    "@eslint/eslintrc": "^3.3.5",
    "@icebreakers/changelog-github": "workspace:*",
    "@icebreakers/commitlint-config": "workspace:*",
    "@icebreakers/eslint-config": "workspace:*",
    "@icebreakers/monorepo": "^4.0.13",
    "@icebreakers/stylelint-config": "workspace:*",
    "@next/eslint-plugin-next": "^16.2.9",
    "@prettier/plugin-xml": "^3.4.2",
    "@tanstack/eslint-plugin-query": "^5.101.1",
    "@types/eslint-plugin-tailwindcss": "^3.17.0",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash": "^4.17.24",
    "@types/lodash-es": "^4.17.12",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^26.0.1",
    "@types/semver": "^7.7.1",
    "@types/set-value": "^4.0.3",
    "@typescript-eslint/types": "^8.62.0",
    "@unocss/eslint-plugin": "66.7.3",
    "@vitest/coverage-v8": "~4.1.9",
    "astro-eslint-parser": "^2.1.0",
    "ci-info": "^4.4.0",
    "cross-env": "^10.1.0",
    "defu": "^6.1.7",
    "es-toolkit": "^1.49.0",
    "eslint": "^10.5.0",
    "eslint-plugin-astro": "^2.1.1",
    "eslint-plugin-mdx": "3.8.1",
    "eslint-plugin-svelte": "^3.20.0",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.5",
    "get-value": "^4.1.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.8",
    "lodash": "^4.18.1",
    "lodash-es": "^4.18.1",
    "micromatch": "^4.0.8",
    "only-allow": "^1.2.2",
    "pathe": "^2.0.3",
    "pkg-types": "^2.3.1",
    "prettier": "^3.8.5",
    "prettier-plugin-astro": "^0.14.1",
    "rimraf": "^6.1.3",
    "set-value": "^4.1.0",
    "stylelint": "^17.14.0",
    "svelte": "^5.56.4",
    "svelte-eslint-parser": "^1.8.0",
    "tsd": "^0.33.0",
    "tsdown": "0.22.3",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "turbo": "^2.10.0",
    "type-fest": "^5.7.0",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "vitest": "~4.1.9",
    "yaml": "^2.9.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
