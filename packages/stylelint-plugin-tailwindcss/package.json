{
  "name": "stylelint-plugin-tailwindcss",
  "type": "module",
  "version": "0.0.3",
  "description": "Stylelint plugin utilities for Tailwind CSS and utility-first selector rules",
  "author": "ice breaker <1324318532@qq.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonofmagic/dev-configs.git",
    "directory": "packages/stylelint-plugin-tailwindcss"
  },
  "bugs": {
    "url": "https://github.com/sonofmagic/dev-configs/issues"
  },
  "keywords": [
    "dev-configs",
    "icebreakers",
    "stylelint",
    "tailwindcss"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "README.zh.md",
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch --sourcemap",
    "build": "tsdown",
    "lint": "eslint src test test-d",
    "test": "vitest run",
    "test:types": "tsd",
    "test:dev": "vitest",
    "release": "pnpm publish",
    "sync": "cnpm sync stylelint-plugin-tailwindcss",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "stylelint": "^17.4.0",
    "tailwindcss": "^3.4.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "dependencies": {
    "postcss-tailwindcss": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "tsd": {
    "directory": "test-d",
    "compilerOptions": {
      "module": "node16",
      "skipLibCheck": true
    }
  }
}
