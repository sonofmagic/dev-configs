{
  "name": "postcss-tailwindcss",
  "type": "module",
  "version": "0.0.0",
  "description": "PostCSS AST utilities for analyzing Tailwind CSS syntax",
  "author": "ice breaker <1324318532@qq.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonofmagic/dev-configs.git",
    "directory": "packages/postcss-tailwindcss"
  },
  "bugs": {
    "url": "https://github.com/sonofmagic/dev-configs/issues"
  },
  "keywords": [
    "dev-configs",
    "icebreakers",
    "postcss",
    "tailwindcss"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "README.zh.md",
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch --sourcemap",
    "build": "tsdown",
    "test": "vitest run",
    "test:types": "tsd",
    "test:dev": "vitest",
    "release": "pnpm publish",
    "sync": "cnpm sync postcss-tailwindcss",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "enhanced-resolve": "^5.20.0",
    "get-tsconfig": "^4.13.6",
    "postcss": "^8.5.6",
    "postcss-selector-parser": "^7.1.0",
    "postcss-value-parser": "^4.2.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "tsd": {
    "directory": "test-d",
    "compilerOptions": {
      "skipLibCheck": true
    }
  }
}
