{
  "name": "stylelint-plugin-no-tailwindcss",
  "type": "module",
  "version": "0.0.0",
  "description": "Stylelint plugin that disallows declaring Tailwind CSS utility selectors",
  "author": "ice breaker <1324318532@qq.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonofmagic/dev-configs.git",
    "directory": "packages/stylelint-plugin-no-tailwindcss"
  },
  "bugs": {
    "url": "https://github.com/sonofmagic/dev-configs/issues"
  },
  "keywords": [
    "dev-configs",
    "icebreakers",
    "stylelint",
    "tailwindcss"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "README.zh.md",
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch --sourcemap",
    "build": "tsup",
    "test": "vitest run",
    "test:dev": "vitest",
    "release": "pnpm publish",
    "sync": "cnpm sync stylelint-plugin-no-tailwindcss",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "stylelint": "^17.4.0",
    "tailwindcss": "^3.4.0 || ^4.0.0"
  },
  "dependencies": {
    "@tailwindcss/node": "^4.2.1",
    "postcss-selector-parser": "^7.1.0",
    "tailwindcss-v3": "npm:tailwindcss@3.4.19"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
