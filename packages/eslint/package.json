{
  "name": "@icebreakers/eslint-config",
  "type": "module",
  "version": "2.0.1",
  "description": "ESLint preset from Icebreaker's dev-configs",
  "author": "ice breaker <1324318532@qq.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonofmagic/dev-configs.git",
    "directory": "packages/eslint"
  },
  "bugs": {
    "url": "https://github.com/sonofmagic/dev-configs/issues"
  },
  "keywords": [
    "dev-configs",
    "eslint-config",
    "icebreaker"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./stylelint": {
      "types": "./dist/stylelint.d.ts",
      "import": "./dist/stylelint.js",
      "require": "./dist/stylelint.cjs"
    },
    "./*": "./*"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./index.d.ts",
  "files": [
    "dist",
    "index.d.ts"
  ],
  "scripts": {
    "dev": "tsdown --watch --sourcemap",
    "build": "tsdown",
    "test": "vitest run",
    "test:types": "tsd",
    "test:dev": "vitest",
    "release": "pnpm publish",
    "sync": "cnpm sync @icebreakers/eslint-config",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "eslint-plugin-pnpm": "^1.4.3"
  },
  "peerDependenciesMeta": {
    "eslint-plugin-pnpm": {
      "optional": true
    }
  },
  "dependencies": {
    "@antfu/eslint-config": "7.7.3",
    "@eslint-react/eslint-plugin": "^3.0.0",
    "@icebreakers/stylelint-config": "workspace:*",
    "@next/eslint-plugin-next": "^16.2.0",
    "@tanstack/eslint-plugin-query": "^5.91.5",
    "eslint-plugin-better-stylelint": "workspace:*",
    "eslint-plugin-better-tailwindcss": "^4.3.2",
    "eslint-plugin-format": "2.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-tailwindcss": "3.18.2",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "stylelint": "^17.5.0"
  },
  "optionalDependencies": {
    "@unocss/eslint-plugin": "66.6.7",
    "eslint-plugin-mdx": "3.7.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "tsd": {
    "directory": "test-d",
    "compilerOptions": {
      "module": "esnext",
      "moduleResolution": "bundler",
      "skipLibCheck": true
    }
  }
}
