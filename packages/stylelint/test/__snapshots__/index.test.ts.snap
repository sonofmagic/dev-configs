{
  "extends": [
    "stylelint-config-standard-scss",
    "stylelint-config-recommended-vue/scss",
    "stylelint-config-recess-order",
  ],
  "overrides": [],
  "plugins": [
    "stylelint-plugin-tailwindcss",
    "stylelint-plugin-tailwindcss/no-invalid-apply",
    "stylelint-plugin-tailwindcss/no-apply",
    "stylelint-plugin-tailwindcss/no-arbitrary-value",
    "stylelint-plugin-tailwindcss/unocss/no-atomic-class",
    "stylelint-plugin-tailwindcss/unocss/no-invalid-apply",
    "stylelint-plugin-tailwindcss/unocss/no-apply",
    "stylelint-plugin-tailwindcss/unocss/no-arbitrary-value",
  ],
  "rules": {
    "at-rule-no-deprecated": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "theme",
          "apply",
          "source",
          "utility",
          "variant",
          "custom-variant",
          "reference",
          "config",
          "plugin",
          "unocss",
        ],
      },
    ],
    "function-name-case": null,
    "media-feature-range-notation": "prefix",
    "scss/at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "theme",
          "apply",
          "source",
          "utility",
          "variant",
          "custom-variant",
          "reference",
          "config",
          "plugin",
          "unocss",
        ],
      },
    ],
    "scss/selector-no-redundant-nesting-selector": true,
    "selector-class-pattern": [
      /\\^\\[a-z\\]\\[a-z0-9\\]\\*\\(\\?:-\\[a-z0-9\\]\\+\\)\\*\\(\\?:__\\[a-z0-9\\]\\+\\(\\?:-\\[a-z0-9\\]\\+\\)\\*\\)\\*\\(\\?:--\\[a-z0-9\\]\\+\\(\\?:-\\[a-z0-9\\]\\+\\)\\*\\)\\*\\$/,
      {
        "message": "Use BEM/OOCSS-friendly class names",
        "resolveNestedSelectors": true,
      },
    ],
    "selector-type-no-unknown": [
      true,
      {
        "ignoreTypes": [
          "page",
        ],
      },
    ],
    "tailwindcss/no-apply": true,
    "tailwindcss/no-arbitrary-value": true,
    "tailwindcss/no-atomic-class": true,
    "tailwindcss/no-invalid-apply": true,
    "unit-no-unknown": [
      true,
      {
        "ignoreUnits": [
          "rpx",
        ],
      },
    ],
    "unocss/no-apply": true,
    "unocss/no-arbitrary-value": true,
    "unocss/no-atomic-class": true,
    "unocss/no-invalid-apply": true,
